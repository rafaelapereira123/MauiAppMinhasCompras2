<?xml version="1.0" encoding="UTF-8" ?>
<Shell
    x:Class="MauiAppMinhasCompras.AppShell"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:local="clr-namespace:MauiAppMinhasCompras"
    xmlns:views="clr-namespace:MauiAppMinhasCompras.Views"
    Title="MauiAppMinhasCompras"
    FlyoutBehavior="Locked">


    <FlyoutItem Title="Produtos" FlyoutDisplayOptions="AsSingleItem">
        <ShellContent ContentTemplate="{DataTemplate views:ListaProduto}" />
    </FlyoutItem>

    <FlyoutItem Title="Relatório" FlyoutDisplayOptions="AsSingleItem">
        <ShellContent ContentTemplate="{DataTemplate views:Relatorio}" />
    </FlyoutItem>

</Shell>
