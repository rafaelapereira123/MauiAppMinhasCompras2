<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="MauiAppMinhasCompras.Views.Relatorio"
             Title="Relatorio">
    <VerticalStackLayout Padding="20">
        <Label Text="Data Inicial"/>
        <DatePicker x:Name="dt_pckInicio"/>

        <Label Text="Data Final"/>
        <DatePicker x:Name="dt_pckFim"/>

        <Button Text="Filtrar" Clicked="Button_Clicked"/>

        <CollectionView x:Name="lst_produtos">
            <CollectionView.ItemTemplate>
                <DataTemplate>
                    <Frame Margin="5">
                        <VerticalStackLayout>
                            <Label Text="{Binding Descricao}" FontAttributes="Bold"/>
                            <Label Text="{Binding Preco, StringFormat='{}{0:c}'}"/>
                            <Label Text="{Binding DataCadastro, StringFormat='Data: {0:dd/MM/yyyy}'}"/>
                        </VerticalStackLayout>
                    </Frame>
                </DataTemplate>
                
            </CollectionView.ItemTemplate>
        </CollectionView>
    </VerticalStackLayout>
</ContentPage>